class Solution {
    public boolean isAnagram(String s, String t) {
        char a[]=s.toCharArray();
        char arr[]=t.toCharArray();
        Arrays.sort(a);
        Arrays.sort(arr);
        String s1=new String(a);
        String s2=new String(arr);
        if(s1.equals(s2)){
            return true;
        }
        return false;
        
    }
}
