class Solution {
    public int[][] transpose(int[][] matrix) {
        int c=matrix[0].length, r=matrix.length;
        int a[][]= new int[c][r];
        for(int i=0;i<r;i++){
            for(int j=0;j<c;j++){
                a[j][i]=matrix[i][j];

            }
        }
        
        return a;
    }
}
