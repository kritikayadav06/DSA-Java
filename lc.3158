
class Solution {
    public int duplicateNumbersXOR(int[] nums) {
        Arrays.sort(nums);

        int ans = 0;
        int i = 0;
        int n = nums.length;

        while (i < n) {
            int count = 1;

            
            while (i + 1 < n && nums[i] == nums[i + 1]) {
                count++;
                i++;
            }

            if (count == 2) {
                ans ^= nums[i];   
            }

            i++;
        }

        return ans;
    }
}
