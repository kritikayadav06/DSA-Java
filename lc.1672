class Solution {
    public int maximumWealth(int[][] accounts) {
        int r=accounts.length, c=accounts[0].length;
         int max=0,sum=0;
        for(int i=0;i<r;i++){
             
            for(int j=0;j<c;j++){
                sum=sum+accounts[i][j];
            }

            if(sum>max){
                max=sum;
                sum=0;
            }
            else{
                sum=0;
            }
        }
        return max;
        
    }
}
